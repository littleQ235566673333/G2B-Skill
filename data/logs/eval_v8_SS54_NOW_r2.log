Sub MoveInvoiceHeaderToTop()
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim i As Long
    Dim foundRow As Long

    Set ws = ThisWorkbook.Worksheets("Statement")
    lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row
    foundRow = 0

    For i = 1 To lastRow
        If ws.Cells(i, 1).Value = "Invoice No." Then
            foundRow = i
            Exit For
        End If
    Next i

    If foundRow > 1 Then
        ws.Rows("1:" & foundRow - 1).Delete
