import pandas as pd
input_path = 'results/runs/g2b-skill-wtq_gpt-5.4/eval/eval_nt-157_tc1/input.csv'
output_path = 'results/runs/g2b-skill-wtq_gpt-5.4/eval/eval_nt-157_tc1/output.txt'

