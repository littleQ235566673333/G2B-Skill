#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

try:
    import fcntl
except ImportError:
    fcntl = None

real = os.environ.get("SE_PIPELINE_REAL_SOFFICE")
lock_path = os.environ.get("SE_PIPELINE_SOFFICE_LOCK")
if not real:
    print("SE_PIPELINE_REAL_SOFFICE is not set", file=sys.stderr)
    sys.exit(127)

def run():
    return subprocess.run([real] + sys.argv[1:]).returncode

if lock_path and fcntl is not None:
    p = Path(lock_path)
    p.parent.mkdir(parents=True, exist_ok=True)
    with open(p, "w") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            code = run()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)
else:
    code = run()
sys.exit(code)
