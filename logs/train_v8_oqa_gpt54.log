# Compute using BLS CPI-U NSA monthly values for 1949:
# Nov 1949 = 23.8, Dec 1949 = 23.6
nov_nom = 155205.0
Dec_nom = 154962.0
cpi_nov = 23.8
cpi_dec = 23.6
nov_real = nov_nom * (cpi_dec / cpi_nov)
dec_real = Dec_nom * (cpi_dec / cpi_dec)
abs_diff = abs(dec_real - nov_real)
abs_pct_diff = abs(dec_real - nov_real) / ((dec_real + nov_real)/2) * 100
print(nov_real, dec_real, abs_diff, abs_pct_diff)
print(round(abs_diff), round(abs_pct_diff, 3))
