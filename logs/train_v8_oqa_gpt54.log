from decimal import Decimal, ROUND_HALF_UP
receipts=Decimal('753')
expend=Decimal('735')
vals=[receipts, expend]
mean=sum(vals)/Decimal(len(vals))
# Gini for 2 values: sum_i sum_j |xi-xj| /(2 n^2 mean)
num=sum(abs(a-b) for a in vals for b in vals)
gini=num/(Decimal(2)*(Decimal(len(vals))**2)*mean)
print('gini', gini)
print('rounded', gini.quantize(Decimal('0.001'), rounding=ROUND_HALF_UP))
print('status', 'surplus' if receipts>expend else 'deficit')
