import math
vals = [9.2, -3.2, 62.9, 16.5, 3.8, 15.3, 72.8, 13.8, 74.2, 16.9, 3.0, 86.7]
vals = [round(v,1) for v in vals]
vals.sort()
print(vals)

def q_type7(data,p):
    x=sorted(data)
    n=len(x)
    h=(n-1)*p+1
    j=int(math.floor(h))
    g=h-j
    if j<=1:
        return x[0]
    if j>=n:
        return x[-1]
    return x[j-1] + g*(x[j]-x[j-1])
q1=q_type7(vals,0.25)
q3=q_type7(vals,0.75)
print(q1,q3,q3-q1)
