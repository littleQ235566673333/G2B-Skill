  tool: shell
  output: Command: python3 -c "from openpyxl import load_workbook
import re
import calendar
from openpyxl.styles import PatternFill

def month_num(mon):
    mon_abbr = {v: k for k, v in enumerate(calendar.month_abbr) if v}
    # Accept any case
    return mon_abbr.get(mon.capitalize(), 0)

def next_month_year(mon, yy):
    n = month_num(mon)
    if n == 0:
        return None, None
    if n == 12:
        return 'Jan', int(yy) + 1
